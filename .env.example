# Required only to run build_plants.py (offline monograph generation via Claude API).
# Not needed for normal development or deployment.
ANTHROPIC_API_KEY=sk-ant-...

# Optional: used by build_plants.py to pull additional evidence from Semantic Scholar.
# Get a key at https://www.semanticscholar.org/product/api
# Rate limit: 1 request/second (cumulative across all endpoints).
SEMANTIC_SCHOLAR_API_KEY=s2k-...

# Stripe Checkout (server-side; never expose the secret values in HTML or Git).
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
SITE_URL=https://bmsarchive.com

# Transactional e-mail delivery after Stripe confirms payment.
RESEND_API_KEY=re_...
ORDER_FROM_EMAIL=BMS Archive <contact@bmsarchive.com>
